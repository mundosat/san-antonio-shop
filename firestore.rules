rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    function currentUser() { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data; }
    function isAdmin() { return signedIn() && currentUser().isAdmin == true; }
    function isApprovedCourier() {
      return signedIn()
        && currentUser().role == 'repartidor'
        && currentUser().approvedForDeliveries == true;
    }

    match /usuarios/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if signedIn();
      allow read: if isAdmin()
        || (signedIn() && resource.data.clienteId == request.auth.uid)
        || (isApprovedCourier() && (resource.data.estado == 'pendiente' || resource.data.repartidorId == request.auth.uid));

      allow update: if isAdmin()
        || (signedIn() && resource.data.clienteId == request.auth.uid)
        || (isApprovedCourier() && (
            resource.data.repartidorId == request.auth.uid
            || (resource.data.estado == 'pendiente' && request.resource.data.repartidorId == request.auth.uid)
        ));

      allow delete: if isAdmin();
    }

    match /repartidores/{uid} {
      allow read: if signedIn();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /calificaciones/{id} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /historial_pedidos/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.clienteId == request.auth.uid);
      allow write: if isAdmin();
    }
  }
}
